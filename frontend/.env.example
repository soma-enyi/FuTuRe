# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in the values.
# Variables prefixed with VITE_ are inlined into the browser bundle by Vite.
# Never put secrets here — anything with VITE_ is visible to end users.
#
# Validation is enforced by:
#   • frontend/src/env.js   — runtime check (throws before the app renders)
#   • frontend/vite.config.js — build-time check (fails `vite build` early)
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Base URL for the backend Stellar Remittance API.
# Must be a fully-qualified URL (scheme + host).
# In local development, Vite proxies /api → http://localhost:3001 automatically,
# but a production build requires this to be set explicitly.
#
# Examples:
#   VITE_API_URL=http://localhost:3001          (local dev)
#   VITE_API_URL=https://api.yourapp.com        (production)
VITE_API_URL=http://localhost:3001


# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# VAPID public key for enabling Web Push notifications.
# Generate a key pair with: npx web-push generate-vapid-keys
# Leave empty to disable push notification support.
VITE_VAPID_PUBLIC_KEY=

# CDN base URL for serving static assets.
# When set, Vite rewrites all asset URLs to use this origin, enabling
# immutable long-term caching via a CDN (e.g. CloudFront, Cloudflare).
# Leave empty to serve assets from the same origin as the app.
#
# Example:
#   VITE_CDN_URL=https://cdn.yourapp.com
VITE_CDN_URL=
